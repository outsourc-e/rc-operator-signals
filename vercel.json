  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm --filter dashboard build:ci",
  "installCommand": "pnpm install --frozen-lockfile",
  "outputDirectory": "apps/dashboard/dist",
  "framework": null,
  "rewrites": [
    { "source": "/:path*", "destination": "/index.html" }
  ]
}
